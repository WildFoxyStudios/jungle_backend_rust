# ── Database ──────────────────────────────────────────────────────────────────
# Local: postgres://user:pass@localhost:5432/dbname
# Neon:  postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://neondb_owner:your_password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DB_PASSWORD=your_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
# During rotation, set JWT_SECRET_PREVIOUS to the old JWT_SECRET value. Tokens
# signed with it will continue to validate until they expire naturally (typically
# 15 minutes for access tokens). Remove this variable once all old tokens expire.
# JWT_SECRET_PREVIOUS=

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# ── Frontend & CORS ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── API Gateway ──────────────────────────────────────────────────────────────
GATEWAY_PORT=8080

# ── NATS (Event Bus) ──────────────────────────────────────────────────────────
NATS_URL=nats://127.0.0.1:4222

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3   # for production: s3, minio, wasabi, spaces, backblaze
MINIO_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
S3_BUCKET=Jungle
S3_REGION=us-east-1

# ── Inter-Service ────────────────────────────────────────────────────────────
INTERNAL_SERVICE_KEY=change-this-to-a-random-internal-key

# ── SQLx ──────────────────────────────────────────────────────────────────────
SQLX_OFFLINE=true

# ── Email (SMTP via lettre) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Jungle

# ── SMS ───────────────────────────────────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=

# ── Push Notifications ────────────────────────────────────────────────────
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY_PATH=
APNS_TOPIC=com.example.Jungle

# ── Web Push (VAPID) ─────────────────────────────────────────────────────
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── Payment Gateways ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_SANDBOX=true
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
COINBASE_COMMERCE_API_KEY=
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=
BRAINTREE_SANDBOX=true
STRIPE_WEBHOOK_SECRET=

# ── Iyzipay ──
IYZIPAY_API_KEY=
IYZIPAY_SECRET_KEY=
IYZIPAY_SANDBOX=true

# ── Cashfree ──
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_SANDBOX=true

# ── YooMoney (YooKassa) ──
YOOMONEY_SHOP_ID=
YOOMONEY_SECRET_KEY=

# ── aamarPay ──
AAMARPAY_STORE_ID=
AAMARPAY_SIGNATURE_KEY=
AAMARPAY_SANDBOX=true

# ── 2Checkout ──
TWOCHECKOUT_MERCHANT_CODE=
TWOCHECKOUT_SECRET_KEY=
TWOCHECKOUT_SANDBOX=true

# ── CoinPayments ──
COINPAYMENTS_MERCHANT_ID=
COINPAYMENTS_PUBLIC_KEY=
COINPAYMENTS_PRIVATE_KEY=
COINPAYMENTS_IPN_SECRET=

# ── PayFast ──
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# ── Paysera ──
PAYSERA_PROJECT_ID=
PAYSERA_SIGN_PASSWORD=
PAYSERA_TEST=1

# ── SecurionPay ──
SECURIONPAY_SECRET_KEY=

# ── N-Genius ──
NGENIUS_API_KEY=
NGENIUS_OUTLET_REF=
NGENIUS_SANDBOX=true

# ── Fortumo ──
FORTUMO_SERVICE_ID=
FORTUMO_SECRET=

# ── PayPro Bitcoin ──
PAYPRO_API_KEY=

# ── Authorize.Net ──
AUTHORIZE_NET_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=
AUTHORIZE_NET_WEBHOOK_SIGNATURE_KEY=
AUTHORIZE_NET_SANDBOX=true

# ── Apple Sign In ──
APPLE_CLIENT_ID=

# ── Backups ──
BACKUP_DIR=/tmp/backups

# ── AI Providers (AI Service) ──────────────────────────────────────────────
# Primary: OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3

# Fallback #1: Anthropic Claude (text only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Fallback #2: Google Gemini (text + image via Imagen)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_IMAGE_MODEL=imagen-3.0-generate-001

# ── Service Ports (defaults) ──────────────────────────────────────────────
# AUTH_SERVICE_URL=http://127.0.0.1:3001
# USER_SERVICE_URL=http://127.0.0.1:3002
# POST_SERVICE_URL=http://127.0.0.1:3003
# MESSAGING_SERVICE_URL=http://127.0.0.1:3004
# MEDIA_SERVICE_URL=http://127.0.0.1:3005
# NOTIFICATION_SERVICE_URL=http://127.0.0.1:3006
# GROUP_PAGE_SERVICE_URL=http://127.0.0.1:3007
# CONTENT_SERVICE_URL=http://127.0.0.1:3008
# COMMERCE_SERVICE_URL=http://127.0.0.1:3009
# ADMIN_SERVICE_URL=http://127.0.0.1:3010
# PAYMENT_SERVICE_URL=http://127.0.0.1:3011
# REALTIME_SERVICE_URL=http://127.0.0.1:3012
# AI_SERVICE_URL=http://127.0.0.1:3013

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info,sqlx=warn,tower_http=debug

# -- Missing Settings (Production/Advanced) ----------------------------------
DB_MAX_CONNECTIONS=10
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER_ARG=1.0

# -- AI Settings -------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4-vision-preview

# -- Storage (S3 / R2 / Wasabi) ----------------------------------------------
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# -- Push Notifications (Advanced) -------------------------------------------
APNS_PRODUCTION=false

# -- SMS Providers (Advanced) ------------------------------------------------
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
INFOBIP_SENDER=

MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# -- Branding ----------------------------------------------------------------
SITE_NAME=Jungle
CURRENCY=USD

# -- Bank Transfer Details ---------------------------------------------------
BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_ACCOUNT=
BANK_TRANSFER_ROUTING=
