DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DB_PASSWORD=your-db-password
REDIS_URL=redis://user:password@host:6379
JWT_SECRET=generate-a-random-64-char-hex-string
JWT_REFRESH_SECRET=generate-another-random-64-char-hex-string
INTERNAL_SERVICE_KEY=generate-a-random-32-char-hex-string
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
RUST_LOG=info,sqlx=warn,tower_http=debug

# ── Storage (r2, s3, or local) ──────────────────────────────────
STORAGE_PROVIDER=local
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_BUCKET=your-bucket
S3_REGION=auto
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_PUBLIC_URL=https://your-public-url.r2.dev

# ── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODERATION_MODEL=omni-moderation-latest

# ── OCR.space (KYC) ────────────────────────────────────────────
OCR_SPACE_API_KEY=your-ocr-api-key

# ── Cloudflare Workers AI ──────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_AI_TOKEN=your-ai-token

# ── Web Push (VAPID) ────────────────────────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com

# ── Turnstile ──────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=your-turnstile-secret

# ── SMTP (Brevo / SendGrid) ────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_ENCRYPTION=starttls

# ── NATS (required for inter-service events in production) ─────
NATS_URL=nats://localhost:4222
# Set to "true" in production to crash on NATS failure (prevents silent event loss)
NATS_REQUIRED=false

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
